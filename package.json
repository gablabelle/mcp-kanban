{
  "name": "mcp-kanban",
  "version": "0.1.0",
  "description": "A local-first AI-native Kanban board for AI agents, powered by the Model Context Protocol",
  "repository": {
    "type": "git",
    "url": "https://github.com/gablabelle/mcp-kanban.git"
  },
  "homepage": "https://github.com/gablabelle/mcp-kanban",
  "bugs": {
    "url": "https://github.com/gablabelle/mcp-kanban/issues"
  },
  "type": "module",
  "bin": {
    "mcp-kanban": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.ts dev",
    "clean": "rm -rf dist",
    "build": "npm run clean && npm run build:server && npm run build:ui",
    "build:server": "tsc -p tsconfig.server.json",
    "build:ui": "vite build",
    "start": "node dist/cli/index.js",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "Gab Labelle",
  "keywords": [
    "kanban",
    "mcp",
    "ai",
    "agents",
    "model-context-protocol",
    "task-management"
  ],
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@hono/node-server": "^1.19.11",
    "@hono/node-ws": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@tailwindcss/typography": "^0.5.19",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.35.2",
    "hono": "^4.12.5",
    "lucide-react": "^0.577.0",
    "open": "^11.0.0",
    "radix-ui": "^1.4.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.0.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
